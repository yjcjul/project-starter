# ============================================================
#  .gitignore - 混合型專案
# ============================================================

# 系統檔案
.DS_Store
Thumbs.db
Desktop.ini

# 編輯器暫存
*.swp
*.swo
*~

# ─── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
.env
*.egg-info/
dist/
build/

# ─── Node.js ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ─── IDE / 編輯器 ──────────────────────────────────────────
.idea/
*.sublime-project
*.sublime-workspace

# ─── 測試 / 覆蓋率 ─────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
coverage/

# ─── 文件備份 ──────────────────────────────────────────────
*.bak
*.backup
.tmp/
temp/

# ─── 其他 ──────────────────────────────────────────────────
*.log
*.tmp
.cache/
