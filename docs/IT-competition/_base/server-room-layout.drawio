        <!-- ===== HA 說明 ===== -->
        <mxCell id="ha-note" value="&lt;b&gt;高可用 (HA) 配置說明：&lt;/b&gt;&lt;br&gt;&lt;br&gt;• DataCore #1 (櫃A) ↔ DataCore #2 (櫃B) 做 Mirror&lt;br&gt;• SAN Switch #1 (櫃A) ↔ SAN Switch #2 (櫃B) 做 ISL 互聯&lt;br&gt;• Storage 各接各自的 SAN Switch&lt;br&gt;• VM Server 可透過任一路徑存取 Storage&lt;br&gt;• 兩台 UPS 各供一櫃，互不影響&lt;br&gt;&lt;br&gt;&lt;b&gt;所有跨櫃連線都經 MPO 光纖配線架轉接&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF;strokeColor=#B85450;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
